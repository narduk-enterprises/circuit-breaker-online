{
  "name": "web",
  "type": "module",
  "private": true,
  "version": "1.4.12",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "db:migrate": "bash ../../tools/db-migrate.sh circuit-breaker-online-db --local --dir drizzle",
    "db:seed": "wrangler d1 execute circuit-breaker-online-db --local --file=drizzle/seed-from-prod.sql",
    "db:pull": "wrangler d1 export circuit-breaker-online-db --remote --output=drizzle/seed-products.sql --table=products && wrangler d1 export circuit-breaker-online-db --remote --output=drizzle/seed-categories.sql --table=categories && cat drizzle/seed-categories.sql drizzle/seed-products.sql > drizzle/seed-from-prod.sql && rm drizzle/seed-categories.sql drizzle/seed-products.sql",
    "db:studio": "drizzle-kit studio",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run",
    "seo:check": "vitest run tests/sitemap-seo.test.ts",
    "quality": "echo 'Turbo dependsOn handles lint + typecheck + format:check'",
    "db:reset": "bash ../../tools/db-migrate.sh circuit-breaker-online-db --local --dir drizzle --reset && pnpm run db:seed",
    "db:ready": "pnpm run db:migrate && pnpm run db:seed"
  },
  "dependencies": {
    "@narduk-enterprises/narduk-nuxt-template-layer": "workspace:*",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "nuxt": "^4.3.1",
    "posthog-js": "^1.356.1",
    "zod": "^4.3.6",
    "@narduk-enterprises/eslint-config": "^1.0.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/ui": "4.5.0",
    "@tailwindcss/vite": "^4.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "nitro-cloudflare-dev": "^0.1.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
