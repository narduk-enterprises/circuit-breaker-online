{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/schemas/config/wrangler.json",
  "name": "circuit-breaker-online",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2025-07-15",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "circuit-breaker-online-db",
      "database_id": "55b3730f-d726-48e5-aa3c-d8e27f7fb78f"
    }
  ],
  "r2_buckets": [
    {
      "binding": "IMAGES",
      "bucket_name": "circuit-breaker-online-images"
    }
  ],
  "routes": [
    {
      "pattern": "circuitbreaker.online",
      "custom_domain": true
    }
  ]
}
