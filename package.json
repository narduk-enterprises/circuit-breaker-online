{
  "name": "circuit-breaker-online",
  "version": "1.3.4",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "doppler run -- pnpm -r build",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "prelint": "pnpm run build:plugins",
    "lint": "pnpm run prelint && turbo run lint",
    "typecheck": "turbo run typecheck",
    "quality": "turbo run quality",
    "setup": "doppler run -- npx tsx tools/init.ts",
    "validate": "doppler run -- npx tsx tools/validate.ts",
    "update-layer": "npx tsx tools/update-layer.ts",
    "clean": "find . -type d \\( -name node_modules -o -name .nuxt -o -name .output -o -name .nitro -o -name .wrangler -o -name .turbo -o -name .data -o -name dist \\) -not -path './.git/*' -prune -exec rm -rf {} +",
    "clean:install": "pnpm run clean && pnpm install && pnpm run db:migrate",
    "db:migrate": "pnpm --filter web run db:migrate",
    "deploy": "pnpm --filter web run deploy",
    "dev:kill": "sh scripts/dev-kill.sh",
    "generate:favicons": "npx tsx tools/generate-favicons.ts",
    "gsc:inspect-urls": "doppler run -- npx tsx tools/gsc-toolbox.ts inspect-urls",
    "predev": "node tools/check-setup.cjs",
    "prebuild": "node tools/check-setup.cjs",
    "predeploy": "node tools/check-setup.cjs",
    "postinstall": "node -e \"if(!require('fs').existsSync('.setup-complete'))console.log('\\n⚠️  Run pnpm run setup before doing anything else! See AGENTS.md.\\n')\""
  },
  "pnpm": {
    "overrides": {
      "nuxt-og-image": "6.0.0-beta.42",
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.13",
    "google-auth-library": "^9.0.0",
    "googleapis": "^144.0.0",
    "sharp": "^0.34.5",
    "turbo": "^2.8.12",
    "tsx": "^4.21.0"
  }
}
